{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autoclip.local/schemas/gene-template.json",
  "title": "GeneTemplate",
  "description": "基因模板配置：面向用户的风格包，映射到底层 Pipeline 参数与 Prompt",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "pipeline"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "模板唯一标识，用于 template_id"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "展示名称"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "模板说明"
    },
    "version": {
      "type": "string",
      "default": "1.0.0"
    },
    "enabled": {
      "type": "boolean",
      "default": true,
      "description": "是否在模板广场展示"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "可选标签，用于筛选"
    },
    "preview": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "video_url": {
          "type": "string",
          "description": "参考视频 URL（外链或 /api/v1/files/... 静态路径）"
        },
        "thumbnail_url": {
          "type": "string",
          "description": "封面图 URL"
        }
      }
    },
    "pipeline": {
      "type": "object",
      "required": [
        "clip_goal"
      ],
      "additionalProperties": false,
      "properties": {
        "clip_goal": {
          "type": "string",
          "description": "映射到 GoalProfile.id（如 golden_quote、knowledge）"
        },
        "video_category": {
          "type": "string",
          "default": "default",
          "description": "视频分类，影响 category 级 Prompt 覆盖"
        },
        "clip_duration_preset": {
          "type": "string",
          "description": "切片时长预设（short / medium / standard 等）"
        }
      }
    },
    "prompts": {
      "type": "object",
      "additionalProperties": false,
      "description": "Prompt 配置；MVP 阶段通过 pack 复用现有 goals 目录",
      "properties": {
        "pack": {
          "type": "string",
          "description": "覆盖 prompt pack 目录名，默认与 clip_goal 的 prompt_pack 一致"
        },
        "overrides": {
          "type": "object",
          "description": "未来：按 key 内联覆盖 prompt 文本",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "rules": {
      "type": "object",
      "description": "扩展规则（字幕样式、是否聚类等），Pipeline 动态化阶段消费",
      "additionalProperties": true,
      "properties": {
        "enable_clustering": {
          "type": "boolean",
          "description": "是否执行 step5 主题聚类"
        },
        "subtitle_style": {
          "type": "string",
          "description": "字幕样式：default | quote_highlight | quote_cinema（legacy，与 overlay 二选一或并存）",
          "enum": [
            "default",
            "quote_highlight",
            "quote_cinema"
          ]
        },
        "overlay": {
          "type": "object",
          "description": "Overlay 管线：composer 编排层，renderer 渲染引擎",
          "additionalProperties": true,
          "properties": {
            "composer": {
              "type": "string",
              "enum": ["none", "quote_cinema", "quote_highlight"],
              "description": "内容编排器"
            },
            "renderer": {
              "type": "string",
              "enum": ["none", "ass_stack", "drawtext"],
              "description": "渲染后端"
            },
            "config": {
              "type": "object",
              "description": "composer 专属排版配置；可与 quote_overlay 合并",
              "additionalProperties": true
            }
          }
        },
        "quote_overlay": {
          "type": "object",
          "description": "字幕叠加排版配置。quote_cinema 使用 cinema 字段；quote_highlight 使用 font_size/box 等字段",
          "additionalProperties": true,
          "properties": {
            "font_file": {
              "type": "string",
              "description": "可选字体文件路径；不填时自动使用内置/系统中文字体"
            },
            "font_size": {
              "type": "integer",
              "minimum": 12,
              "maximum": 120,
              "description": "字号"
            },
            "font_color": {
              "type": "string",
              "description": "文字颜色，支持 white、#RRGGBB、#RRGGBBAA 等"
            },
            "border_color": {
              "type": "string",
              "description": "描边颜色"
            },
            "border_width": {
              "type": "integer",
              "minimum": 0,
              "maximum": 20,
              "description": "描边宽度"
            },
            "box": {
              "type": "boolean",
              "description": "是否启用半透明底框"
            },
            "box_color": {
              "type": "string",
              "description": "底框颜色"
            },
            "box_border_width": {
              "type": "integer",
              "minimum": 0,
              "maximum": 80,
              "description": "底框内边距"
            },
            "margin_bottom": {
              "type": "integer",
              "minimum": 0,
              "maximum": 500,
              "description": "距离底部像素"
            },
            "line_spacing": {
              "type": "integer",
              "minimum": 0,
              "maximum": 80,
              "description": "多行文字行距"
            },
            "max_chars_per_line": {
              "type": "integer",
              "minimum": 0,
              "maximum": 80,
              "description": "自动换行每行最多字符数"
            },
            "x": {
              "type": "string",
              "description": "FFmpeg drawtext x 表达式"
            },
            "y": {
              "type": "string",
              "description": "FFmpeg drawtext y 表达式"
            },
            "shadow_x": {
              "type": "integer",
              "minimum": -20,
              "maximum": 20
            },
            "shadow_y": {
              "type": "integer",
              "minimum": -20,
              "maximum": 20
            },
            "shadow_color": {
              "type": "string"
            },
            "layout": {
              "type": "string",
              "enum": ["cinema"],
              "description": "quote_cinema 布局标识"
            },
            "content_priority": {
              "type": "array",
              "items": { "type": "string" },
              "description": "字幕文案来源优先级，如 content / outline / recommend_reason"
            },
            "base_font_size": { "type": "integer", "minimum": 12, "maximum": 120 },
            "margin_left": { "type": "integer", "minimum": 0, "maximum": 500 },
            "margin_left_ratio": { "type": "number", "minimum": 0, "maximum": 0.5 },
            "margin_bottom_ratio": { "type": "number", "minimum": 0, "maximum": 0.5 },
            "max_headline_chars": { "type": "integer", "minimum": 4, "maximum": 80 },
            "max_body_chars": { "type": "integer", "minimum": 4, "maximum": 120 },
            "max_body_points": { "type": "integer", "minimum": 0, "maximum": 5 },
            "headline_color": { "type": "string", "description": "主金句颜色 #RRGGBB" },
            "body_color": { "type": "string", "description": "副文案颜色 #RRGGBB" },
            "headline_size_scale": { "type": "number", "minimum": 0.5, "maximum": 2 },
            "body_size_scales": {
              "type": "array",
              "items": { "type": "number" },
              "description": "各条副文案字号比例"
            },
            "line_height_factor": { "type": "number", "minimum": 1, "maximum": 2 },
            "min_font_size": { "type": "integer", "minimum": 10, "maximum": 48 },
            "headline_bold": { "type": "boolean" },
            "headline_outline": { "type": "integer", "minimum": 0, "maximum": 8 },
            "headline_shadow": { "type": "integer", "minimum": 0, "maximum": 8 },
            "body_shadow": { "type": "integer", "minimum": 0, "maximum": 8 },
            "show_quote_mark": { "type": "boolean" },
            "show_emphasis_line": { "type": "boolean" },
            "show_tagline_en": { "type": "boolean" },
            "caps_label": { "type": "string" },
            "role_styles": { "type": "object", "additionalProperties": true },
            "alignment": {
              "type": "string",
              "enum": ["bottom-left", "bottom-center", "bottom-right"],
              "description": "quote_cinema 字幕对齐方式"
            },
            "margin_right": { "type": "integer", "minimum": 0, "maximum": 500 },
            "margin_right_ratio": { "type": "number", "minimum": 0, "maximum": 0.5 },
            "color_preset": {
              "type": "string",
              "enum": ["golden_cinema", "mono_white", "calm_ink", "accent_blue"],
              "description": "配色方案；显式 headline_color/body_color 优先于 preset"
            }
          }
        }
      }
    }
  }
}
